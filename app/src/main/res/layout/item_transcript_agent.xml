<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="56dp">

    <!-- AI Avatar -->
    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_avatar_agent"
        android:gravity="center"
        android:text="AI"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_agent"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <TextView
            android:id="@+id/tvTranscriptText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/bubble_agent_text"
            android:textSize="14sp"
            tools:text="Hello!!" />

        <TextView
            android:id="@+id/tvTranscriptStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_weak"
            android:textSize="10sp"
            android:visibility="gone"
            tools:text="END" />

    </LinearLayout>

    <!-- Hidden field kept for ViewHolder compatibility -->
    <TextView
        android:id="@+id/tvTranscriptType"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
